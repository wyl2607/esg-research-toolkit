# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# App settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
ADMIN_API_TOKEN=

# Production safety
# Set to your deployed frontend origins, comma-separated. Do not use '*' in production.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# Database
DATABASE_URL=sqlite:///./data/esg_toolkit.db

# Literature pipeline
ARXIV_MAX_RESULTS=20
ARXIV_DOWNLOAD_PDF=true

# Logging
LOG_LEVEL=INFO
BATCH_MAX_WORKERS=2
